load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")

cmake(
    name = "sdl",
    lib_source = "@sdl_src//:all",
    cache_entries = {
        "CMAKE_BUILD_TYPE": "Release",
        "SDL_SHARED": "OFF",
        "SDL_STATIC": "ON",
        "SDL_TEST": "OFF",
        "SDL_AUDIO": "ON",
        "SDL_VIDEO": "ON",
        "SDL_GPU": "ON",
        "SDL_RENDER": "ON",
        "SDL_CAMERA": "ON",
        "SDL_WAYLAND": "ON",
        "SDL_X11": "ON",
        "SDL_X11_XSCRNSAVER": "OFF",
        "SDL_X11_XTEST": "OFF",
        "SDL_TEST_LIBRARY": "OFF",
        "SDL_TESTS": "OFF",
        "SDL_EXAMPLES": "OFF",
        "SDL_CCACHE": "ON"
    },
    out_static_libs = ["libSDL3.a"],
    out_lib_dir = "lib64",
    visibility = ["//visibility:public"],
)
