# rules_foreign_cc bootstraps make/cmake as host (exec) tools.
# ccache at /usr/lib64/ccache/gcc breaks inside Bazel's sandbox because
# it cannot write to its cache directory. Force real compiler binaries for
# both target and host/exec toolchains.
build --action_env=CC=/usr/bin/gcc
build --action_env=CXX=/usr/bin/g++
build --action_env=LD=/usr/bin/ld
build --host_action_env=CC=/usr/bin/gcc
build --host_action_env=CXX=/usr/bin/g++
build --host_action_env=LD=/usr/bin/ld

# Prevent Bazel from inheriting PATH entries that include ccache wrappers
build --action_env=PATH=/usr/bin:/bin
build --host_action_env=PATH=/usr/bin:/bin
