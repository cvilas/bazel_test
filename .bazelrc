# Bazel's auto-configured C++ toolchain picks up ccache from /usr/lib64/ccache/gcc.
# ccache fails inside Bazel's sandbox (can't write to its cache dir).
# Setting CCACHE_DISABLE=1 makes ccache transparently exec the real compiler
# without caching, which works fine inside the sandbox.
build --action_env=CCACHE_DISABLE=1
build --host_action_env=CCACHE_DISABLE=1
